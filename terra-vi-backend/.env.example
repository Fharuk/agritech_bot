# Terra VI Backend — Phase 2
# Copy to .env and fill in values

# ── No API keys needed for core inference ─────────────────────────────────────
# Models run locally. No HuggingFace key needed at runtime.
# HUGGINGFACE_TOKEN=hf_xxx   # Optional — only for faster model downloads

# ── Admin CMS (CHANGE THESE before production!) ───────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=terravi2025

# ── WhatsApp bot (Optional) ───────────────────────────────────────────────────
# Get free sandbox at: https://console.twilio.com/messaging/try-it-out/whatsapp-learn
# TWILIO_ACCOUNT_SID=ACxxxxx
# TWILIO_AUTH_TOKEN=xxxxx
# TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./terra_vi.db

# ── App ────────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
# For production deployment (Fly.io):
# ENVIRONMENT=production
# ALLOWED_ORIGINS=https://your-frontend.vercel.app
